---
// A terminal-style chip inviting people to `ssh charliegleason.com`, with
// copy-on-click. Interactivity is a small inline <script> (matching
// ThemeToggle.astro), and every animation is a CSS transition/keyframe —
// the site doesn't use an animation library.
const command = "ssh charliegleason.com";
---

<button
  type="button"
  data-ssh-copy
  data-command={command}
  aria-label={`Copy "${command}" to clipboard`}
  class="group/ssh relative inline-flex items-center gap-3 rounded-lg border
         border-neutral-900/10 dark:border-neutral-100/10
         bg-neutral-100/70 dark:bg-neutral-800/40 backdrop-blur-sm
         px-3 py-2 font-mono text-xs text-neutral-700 dark:text-neutral-300
         transition-all duration-200 outline-2 outline-offset-2 outline-yellow-500
         hover:border-yellow-500/50 dark:hover:border-yellow-400/50
         hover:bg-yellow-400/10 hover:-translate-y-px
         active:translate-y-0
         focus-visible:outline"
>
  {/* Copied pill — floats up out of the chip on success */}
  <span
    class="ssh-copied pointer-events-none absolute -top-2 left-1/2 -translate-x-1/2
           rounded-full bg-yellow-500 dark:bg-yellow-400 px-2 py-0.5
           text-[0.5rem] font-display uppercase tracking-wider text-yellow-950
           opacity-0"
    aria-hidden="true"
  >
    Copied
  </span>

  {/* Faux traffic lights — grey until hover, then they light up */}
  <span class="hidden sm:flex items-center gap-1.5" aria-hidden="true">
    <span
      class="h-2 w-2 rounded-full bg-neutral-400/50 dark:bg-neutral-600
             transition-colors duration-300 group-hover/ssh:bg-red-400"
    ></span>
    <span
      class="h-2 w-2 rounded-full bg-neutral-400/50 dark:bg-neutral-600
             transition-colors duration-300 delay-[50ms] group-hover/ssh:bg-yellow-400"
    ></span>
    <span
      class="h-2 w-2 rounded-full bg-neutral-400/50 dark:bg-neutral-600
             transition-colors duration-300 delay-100 group-hover/ssh:bg-green-400"
    ></span>
  </span>

  {/* The command */}
  <span class="flex items-baseline">
    <span class="mr-2 select-none text-yellow-600 dark:text-yellow-400">❯</span>
    <span>{command}</span>
    <span
      class="ssh-caret ml-0.5 inline-block h-[1em] w-[0.55em] translate-y-[0.1em]
             bg-yellow-600/80 dark:bg-yellow-400/80"
      aria-hidden="true"
    ></span>
  </span>

  {/* Copy → check icon stack */}
  <span
    class="relative ml-0.5 flex h-4 w-4 items-center justify-center
           text-neutral-500 dark:text-neutral-400
           transition-colors group-hover/ssh:text-yellow-600 dark:group-hover/ssh:text-yellow-400"
    aria-hidden="true"
  >
    <svg
      class="ssh-icon ssh-icon--copy absolute h-4 w-4"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <rect x="9" y="9" width="11" height="11" rx="2"></rect>
      <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
    </svg>
    <svg
      class="ssh-icon ssh-icon--check absolute h-4 w-4 text-green-500 dark:text-green-400"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2.5"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="M20 6 9 17l-5-5"></path>
    </svg>
  </span>
</button>

<style>
  /* Blinking terminal caret */
  .ssh-caret {
    animation: ssh-blink 1.1s steps(1) infinite;
  }

  @keyframes ssh-blink {
    0%,
    50% {
      opacity: 1;
    }
    50.01%,
    100% {
      opacity: 0;
    }
  }

  /* Copy ⇄ check cross-fade. Default: copy shown, check hidden. */
  .ssh-icon {
    transition:
      opacity 0.2s ease,
      transform 0.2s ease;
  }
  .ssh-icon--check {
    opacity: 0;
    transform: scale(0.5);
  }

  /* Copied state, toggled from the inline script */
  .is-copied .ssh-icon--copy {
    opacity: 0;
    transform: scale(0.5);
  }
  .is-copied .ssh-icon--check {
    opacity: 1;
    transform: scale(1);
  }

  .ssh-copied {
    transition:
      opacity 0.25s ease,
      transform 0.25s ease;
    transform: translate(-50%, 4px);
  }
  .is-copied .ssh-copied {
    opacity: 1;
    transform: translate(-50%, -2px);
  }

  /* Yellow ring flash on copy */
  .is-copied {
    animation: ssh-flash 0.5s ease-out;
  }

  @keyframes ssh-flash {
    0% {
      box-shadow: 0 0 0 0 theme("colors.yellow.400" / 60%);
    }
    100% {
      box-shadow: 0 0 0 8px theme("colors.yellow.400" / 0%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ssh-caret,
    .is-copied {
      animation: none;
    }
    .ssh-icon,
    .ssh-copied {
      transition: none;
    }
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>("[data-ssh-copy]").forEach((button) => {
    let timeout: ReturnType<typeof setTimeout> | undefined;

    button.addEventListener("click", async () => {
      const command = button.dataset.command ?? "";

      try {
        await navigator.clipboard.writeText(command);
      } catch {
        // Fallback for browsers without the async clipboard API.
        const input = document.createElement("textarea");
        input.value = command;
        input.setAttribute("readonly", "");
        input.style.position = "fixed";
        input.style.opacity = "0";
        document.body.appendChild(input);
        input.select();
        try {
          document.execCommand("copy");
        } catch {
          /* nothing else we can do */
        }
        document.body.removeChild(input);
      }

      // Re-trigger the flash animation cleanly if clicked repeatedly.
      button.classList.remove("is-copied");
      void button.offsetWidth;
      button.classList.add("is-copied");

      clearTimeout(timeout);
      timeout = setTimeout(() => button.classList.remove("is-copied"), 1800);
    });
  });
</script>
